bead: frankenjax-vfogq
pass: 70
lever: terminal F64 tensor Add DAG dense-slot replay in fj-backend-cpu dependency scheduler
target: backend_scheduler_tensor_shapes/tensor_branched_fanin/32x4x64

profile:
  backend_scheduler_tensor_shapes/tensor_branched_fanin/32x4x64:
    baseline: 107.631075 us [107.158095, 108.107316] on ts2
    rebench: 34.835610 us [34.313234, 35.376128] on ts2
    speedup_midpoint: 3.089674
    speedup_conservative_interval: 3.029022
  guard_rows:
    16x4x4: baseline 33.603290 us [33.439176, 33.806503], rebench 33.098460 us [32.757758, 33.466962]
    16x4x64: baseline 44.412860 us [44.240781, 44.599801], rebench 43.283114 us [42.606901, 44.044824]
    16x4x1024: baseline 2453.971002 us [2428.147960, 2481.635824], rebench 2580.492547 us [2538.801614, 2622.394660]
    16x4x4096: baseline 2749.654712 us [2718.157961, 2779.626424], rebench 2615.482587 us [2583.038739, 2647.386428]
