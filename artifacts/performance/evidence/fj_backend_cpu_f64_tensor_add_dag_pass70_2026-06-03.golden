golden_outputs:
  terminal_dag_32x4_input_0_1_2_3: [F64(128.0), F64(160.0), F64(192.0), F64(224.0)]
  terminal_dag_32x4_bits: [0x4060000000000000, 0x4064000000000000, 0x4068000000000000, 0x406c000000000000]
  visible_intermediate_fallback_4x2_input_0_1_outvars_2_12: [[F64(1.0), F64(2.0)], [F64(8.0), F64(12.0)]]

isomorphism:
  order: accepted DAGs replay equations in source order for every tensor element
  tie_breaking: ready-wave metadata is reconstructed by dependency level; visible intermediates, multi-output programs, and nonterminal segments fall back
  floating_point: F64 additions are applied in exactly the original per-equation order; no reassociation, reduction tree rewrite, or element reordering is introduced
  rng: no RNG surface
  storage: dense F64 sources return dense F64 outputs; literal-backed F64 sources return literal-backed outputs, preserving the visible storage shape used by existing tests
  errors: sparse VarIds, missing inputs, non-Add primitives, params, effects, sub-jaxprs, mismatched tensor shapes, mismatched tensor lengths, non-F64 tensors, segments under 128 equations, and tensors over 128 elements keep the existing scheduler/evaluator path
