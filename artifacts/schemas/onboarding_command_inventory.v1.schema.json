{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frankenjax.dev/schemas/onboarding_command_inventory.v1.schema.json",
  "title": "FrankenJAX Onboarding Command Inventory v1",
  "description": "Inventory of documented commands with classification and replay status for fresh-clone onboarding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bead_id",
    "generated_at_unix_ms",
    "status",
    "description",
    "source_docs",
    "commands",
    "summary",
    "issues",
    "replay_command"
  ],
  "properties": {
    "schema_version": {
      "const": "frankenjax.onboarding-command-inventory.v1"
    },
    "bead_id": {
      "type": "string",
      "pattern": "^frankenjax-[a-z0-9.]+$"
    },
    "generated_at_unix_ms": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source_docs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command_entry"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_commands",
        "green_count",
        "yellow_count",
        "red_count",
        "mandatory_smoke_count",
        "ci_gate_count",
        "optional_oracle_count",
        "long_running_count",
        "environment_specific_count",
        "schematic_count",
        "skip_count",
        "executable_smoke_count",
        "source_doc_ref_count",
        "evidence_ref_count"
      ],
      "properties": {
        "total_commands": {
          "type": "integer",
          "minimum": 0
        },
        "green_count": {
          "type": "integer",
          "minimum": 0
        },
        "yellow_count": {
          "type": "integer",
          "minimum": 0
        },
        "red_count": {
          "type": "integer",
          "minimum": 0
        },
        "mandatory_smoke_count": {
          "type": "integer",
          "minimum": 0
        },
        "ci_gate_count": {
          "type": "integer",
          "minimum": 0
        },
        "optional_oracle_count": {
          "type": "integer",
          "minimum": 0
        },
        "long_running_count": {
          "type": "integer",
          "minimum": 0
        },
        "environment_specific_count": {
          "type": "integer",
          "minimum": 0
        },
        "schematic_count": {
          "type": "integer",
          "minimum": 0
        },
        "skip_count": {
          "type": "integer",
          "minimum": 0
        },
        "executable_smoke_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_doc_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_ref_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "replay_command": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "command_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command",
        "smoke_command",
        "classification",
        "expected_exit",
        "skip_reason",
        "replay_command",
        "env_allowlist",
        "feature_flags",
        "evidence_status",
        "evidence_refs",
        "source_refs",
        "artifact_refs"
      ],
      "properties": {
        "command_id": {
          "type": "string",
          "pattern": "^cmd_[a-z0-9_]+$"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "smoke_command": {
          "type": ["string", "null"]
        },
        "classification": {
          "type": "string",
          "enum": [
            "mandatory_local_smoke",
            "ci_gate",
            "long_running",
            "optional_oracle",
            "environment_specific",
            "schematic"
          ]
        },
        "expected_exit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "skip_reason": {
          "type": ["string", "null"]
        },
        "replay_command": {
          "type": "string",
          "minLength": 1
        },
        "env_allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "feature_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_status": {
          "type": "string",
          "enum": ["green", "yellow", "red"]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
